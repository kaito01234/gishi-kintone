{
  "manifest_version": 3,
  "name": "gishi-kintone",
  "version": "1.0.1",
  "description": "定型文を設定して、kintoneのレコード詳細画面からコピーできるChrome拡張機能",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.cybozu.com/k/*", "https://*.cybozu-dev.com/k/*", "https://*.kintone.com/k/*", "https://*.kintone-dev.com/k/*", "https://*.cybozu.cn/k/*", "https://*.cybozu-dev.cn/k/*"],
      "js": ["kintone-bridge.js"],
      "world": "MAIN"
    },
    {
      "matches": ["https://*.cybozu.com/k/*", "https://*.cybozu-dev.com/k/*", "https://*.kintone.com/k/*", "https://*.kintone-dev.com/k/*", "https://*.cybozu.cn/k/*", "https://*.cybozu-dev.cn/k/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
